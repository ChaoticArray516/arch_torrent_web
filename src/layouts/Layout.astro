---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Starfield from '../components/background/Starfield.astro';
import Aurora from '../components/background/Aurora.astro';
import { ClientRouter } from 'astro:transitions';

/**
 * Layout Component - Galactic Tide Theme v4.0
 * The main layout wrapper for all pages in the portfolio website.
 *
 * Starlight Commentary:
 * A ship invisible to interstellar traffic control (search engines) or
 * inaccessible to certain crew members (visitors with disabilities) is but
 * a splendid isolation. SEO optimization is our "hyperspace beacon," ensuring
 * search engines correctly index our coordinates. WCAG accessibility standards
 * serve as our "universal translator," ensuring all users can navigate our cosmos.
 *
 * Features:
 * - Comprehensive SEO meta tags with Astro.url and Astro.site
 * - Open Graph and Twitter Card support for social sharing
 * - Canonical URLs for SEO
 * - Hyperspace ViewTransitions for SPA-like navigation
 * - Dark mode support with inline theme script
 * - Accessibility: Skip navigation link (WCAG 2.4.1)
 * - Accessibility: Semantic HTML landmarks and ARIA labels
 * - Accessibility: prefers-reduced-motion support (STEP-13)
 */

interface Props {
  /** Page title - displayed in browser tab and SEO */
  title: string;
  /** Page description - used for SEO meta tags */
  description: string;
  /** Optional canonical URL for SEO */
  canonical?: string;
  /** Optional Open Graph image path (relative to site root) */
  ogImage?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-image.jpg',
} = Astro.props;

// Construct full title with site name
const fullTitle = `${title} | Portfolio`;

// Build absolute URLs using Astro.site
const canonicalURL = canonical ? new URL(canonical, Astro.site) : Astro.url;
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon - crossorigin attribute prevents dev server cross-origin warnings -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" crossorigin="anonymous" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Portfolio" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <title>{fullTitle}</title>

    <!-- View Transitions for SPA-like navigation -->
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-transparent text-text-bright">
    {/*
      Galactic Tide Background - Layered cosmic visual experience
      - Aurora: Multi-layered tidal aurora (-z-10)
      - Starfield: Colorful canvas-based flowing stars (-z-20)
    */}
    <Aurora />
    <Starfield />

    {/*
      Skip Navigation Link (WCAG 2.4.1 - Bypass Blocks)
      - Hidden visually but available to screen readers
      - Becomes visible when focused (keyboard navigation)
      - Allows keyboard users to skip repetitive navigation
    */}
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-sea-surface focus:text-space-void focus:rounded-lg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-sea-surface"
    >
      Skip to main content
    </a>

    {/* Content wrapper - z-10 to appear above background layers */}
    <div class="relative z-10 flex flex-col min-h-screen">
      {/* Header landmark - semantic navigation region */}
      <Header />

      {/* Main content landmark - target for skip link */}
      <main id="main-content" class="flex-grow" role="main" tabindex="-1">
        <slot />
      </main>

      {/* Footer landmark - semantic contentinfo region */}
      <Footer />
    </div>
  </body>
</html>
