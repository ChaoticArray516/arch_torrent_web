---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

/**
 * Blog Index Page
 * Displays a list of all blog posts from the content collection.
 *
 * Features:
 * - Server-side fetching of blog posts at build time
 * - Static generation of all post links
 * - Responsive grid layout for post cards
 * - Publication date formatting
 */

// Fetch all blog posts from content collection
const posts = await getCollection('blog');

// Sort posts by publication date (newest first)
posts.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

// Format date for display
const formatDate = (date: Date): string => {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
};
---

<Layout
  title="Blog"
  description="Thoughts on web development, software engineering, and technology."
>
  <section class="container mx-auto px-4 py-20">
    {/* Page Header */}
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-star-light mb-4">
        Interstellar Logs
      </h1>
      <p class="text-lg text-star-dim max-w-2xl mx-auto">
        Chronicles from the digital cosmos - thoughts on web development, engineering, and technology.
      </p>
    </div>

    {/* Blog Posts Grid */}
    {posts.length > 0 ? (
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <article class="group flex flex-col overflow-hidden rounded-xl border border-star-light/10 bg-ocean-abyss/30 backdrop-blur-md shadow-lg transition-all duration-300 hover:border-biolume-cyan/50 hover:shadow-[0_0_30px_rgba(51,187,197,0.2)] hover:-translate-y-2">
            {/* Post Link Wrapper */}
            <a href={`/blog/${post.id}/`} class="flex flex-col flex-grow p-6">
              {/* Post Meta */}
              <div class="flex items-center gap-2 text-sm text-star-dim mb-3">
                <time datetime={post.data.publishedAt.toISOString()}>
                  {formatDate(post.data.publishedAt)}
                </time>
              </div>

              {/* Post Title */}
              <h2 class="text-xl font-semibold text-star-light mb-3 group-hover:text-biolume-cyan transition-colors duration-300">
                {post.data.title}
              </h2>

              {/* Post Summary */}
              <p class="text-star-dim line-clamp-3 mb-4 flex-grow">
                {post.data.summary}
              </p>

              {/* Tags */}
              <div class="flex flex-wrap gap-2 mt-auto">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-biolume-cyan/20 text-biolume-cyan border border-biolume-cyan/30">
                    {tag}
                  </span>
                ))}
                {post.data.tags.length > 3 && (
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-star-light/10 text-star-dim border border-star-light/20">
                    +{post.data.tags.length - 3}
                  </span>
                )}
              </div>

              {/* Read More Link */}
              <div class="mt-4 flex items-center text-sm font-medium text-biolume-cyan group-hover:text-biolume-teal transition-colors duration-300">
                Read transmission
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1"
                >
                  <path
                    fill-rule="evenodd"
                    d="M3 10a.75.75 0 01.75-.75h10.638l-3.96-3.96a.75.75 0 111.06-1.06l5.25 5.25a.75.75 0 010 1.06l-5.25 5.25a.75.75 0 11-1.06-1.06l3.96-3.96H3.75A.75.75 0 013 10z"
                    clip-rule="evenodd"
                  />
                </svg>
              </div>
            </a>
          </article>
        ))}
      </div>
    ) : (
      /* Empty State */
      <div class="text-center py-16">
        <p class="text-star-dim">No transmissions recorded yet. Check back soon!</p>
      </div>
    )}
  </section>
</Layout>
