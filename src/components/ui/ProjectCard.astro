---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Tag from './Tag.astro';
// Import placeholder for fallback
import placeholderImage from '../../assets/placeholder-cover.svg';

/**
 * ProjectCard Component
 * Displays a project card with title, description, tech stack, and links.
 *
 * Features:
 * - Displays project information from content collection
 * - Shows tech stack as tags
 * - Links to demo and repository
 * - View Transitions support for smooth navigation
 * - Zero JavaScript - pure static HTML/CSS
 * - Optimized images using Astro's Image component (STEP-13)
 *
 * Performance Optimization:
 * - Uses astro:assets Image component for automatic optimization
 * - Generates multiple widths (300, 600, 900) for responsive images
 * - Converts to WebP format for smaller file sizes
 * - Proper srcset and sizes attributes for optimal loading
 */

interface Props {
  /** Project entry from content collection */
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { data, id } = project;

/**
 * Import project cover image
 * Using dynamic import with glob pattern for build-time optimization
 * Falls back to null if image doesn't exist (placeholder will show)
 */
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/**/*.{jpg,jpeg,png,webp,gif}', { eager: true });
const coverImagePath = `/src/assets/${data.coverImage}`;
const coverImage = images[coverImagePath]?.default;

// Map category to display label
const categoryLabels: Record<string, string> = {
  web: 'Web',
  mobile: 'Mobile',
  tool: 'Tool',
  'open-source': 'Open Source',
};

// Map status to display label and color
const statusConfig: Record<string, { label: string; variant: 'success' | 'warning' | 'default' }> = {
  live: { label: 'Live', variant: 'success' },
  archived: { label: 'Archived', variant: 'warning' },
  wip: { label: 'WIP', variant: 'default' },
};

const status = statusConfig[data.status];

// Generate unique transition names for this project
const transitionName = `project-${id}`;
const imageTransitionName = `project-image-${id}`;
const titleTransitionName = `project-title-${id}`;
---

<article
  class="group relative flex flex-col overflow-hidden rounded-xl border border-star-light/10 bg-ocean-abyss/30 backdrop-blur-md shadow-lg transition-all duration-300 hover:border-biolume-cyan/50 hover:shadow-[0_0_30px_rgba(51,187,197,0.2)] hover:-translate-y-2"
  transition:name={transitionName}
>
  {/* Cover Image - Optimized with Astro Image component (STEP-13) */}
  <div
    class="aspect-video w-full bg-ocean-deep/50 flex items-center justify-center overflow-hidden border-b border-star-light/10"
    transition:name={imageTransitionName}
  >
    {coverImage ? (
      /* Optimized image with multiple widths and WebP format */
      <Image
        src={coverImage}
        alt={data.title}
        widths={[300, 600, 900]}
        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
        format="webp"
        class="w-full h-full object-cover"
        loading="lazy"
        decoding="async"
      />
    ) : (
      /* Fallback placeholder when image is not available */
      <Image
        src={placeholderImage}
        alt={data.title}
        class="w-full h-full object-cover"
        loading="lazy"
        decoding="async"
      />
    )}
  </div>

  {/* Content */}
  <div class="flex flex-col flex-grow p-5">
    {/* Header */}
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3
        class="text-lg font-semibold text-star-light line-clamp-1 group-hover:text-biolume-cyan transition-colors duration-300"
        transition:name={titleTransitionName}
      >
        {data.title}
      </h3>
      {data.featured && (
        <span class="flex-shrink-0 text-biolume-lime drop-shadow-[0_0_8px_rgba(200,245,96,0.6)]" title="Featured Project">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
            <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
          </svg>
        </span>
      )}
    </div>

    {/* Description */}
    <p class="text-sm text-star-dim line-clamp-2 mb-4 grow">
      {data.description}
    </p>

    {/* Meta Info */}
    <div class="flex items-center gap-2 mb-3">
      <Tag variant="secondary" size="sm">{categoryLabels[data.category]}</Tag>
      <Tag variant={status.variant} size="sm">{status.label}</Tag>
    </div>

    {/* Tech Stack */}
    <div class="flex flex-wrap gap-1.5 mb-4">
      {data.techStack.slice(0, 4).map((tech) => (
        <Tag variant="default" size="sm">{tech}</Tag>
      ))}
      {data.techStack.length > 4 && (
        <Tag variant="default" size="sm">+{data.techStack.length - 4}</Tag>
      )}
    </div>

    {/* Links */}
    {data.links && (
      <div class="flex items-center gap-3 pt-3 border-t border-star-light/10">
        {data.links.demo && (
          <a
            href={data.links.demo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 text-sm font-medium text-biolume-cyan hover:text-biolume-teal transition-colors duration-300"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
              <path d="M12.232 4.232a2.5 2.5 0 013.536 3.536l-1.225 1.224a.75.75 0 001.061 1.06l1.224-1.224a4 4 0 00-5.656-5.656l-3 3a4 4 0 00-.225 5.456.75.75 0 00.977-1.138 2.5 2.5 0 01.142-3.412l3-3z" />
              <path d="M11.603 7.963a.75.75 0 00-.977 1.138 2.5 2.5 0 01.142 3.412l-3 3a2.5 2.5 0 01-3.536-3.536l1.225-1.224a.75.75 0 00-1.061-1.06l-1.224 1.224a4 4 0 105.656 5.656l3-3a4 4 0 00.225-5.456.75.75 0 00-.977 1.138z" />
            </svg>
            Live Demo
          </a>
        )}
        {data.links.github && (
          <a
            href={data.links.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 text-sm font-medium text-star-dim hover:text-star-light transition-colors duration-300"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
              <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd" />
            </svg>
            Source
          </a>
        )}
      </div>
    )}
  </div>

  {/* Featured Badge */}
  {data.featured && (
    <div class="absolute top-3 right-3">
      <span class="sr-only">Featured Project</span>
    </div>
  )}
</article>
