---
import { cn } from '../../lib/utils';

/**
 * Button Component
 * A versatile button component that renders as either a button or anchor element
 * based on the presence of an href prop. Supports multiple variants and sizes.
 *
 * Features:
 * - Zero JavaScript - pure HTML/CSS rendered at build time
 * - Dynamic tag rendering (<button> or <a>)
 * - Tailwind CSS styling with variant/size modifiers
 * - Full TypeScript support with proper prop types
 */

interface Props {
  /** Visual style variant */
  variant?: 'primary' | 'secondary' | 'ghost' | 'outline';
  /** Size preset */
  size?: 'sm' | 'md' | 'lg';
  /** Optional href - when provided, renders as <a> tag */
  href?: string;
  /** Enable magnetic/gravitational hover effect */
  magnetic?: boolean;
  /** Additional CSS classes */
  class?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  magnetic = false,
  class: className,
  ...rest
} = Astro.props;

// Dynamically choose the HTML tag based on href presence
// This allows a single component to handle both button and link semantics
const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  data-magnetic={magnetic ? 'true' : undefined}
  class={cn(
    // Base styles
    'inline-flex items-center justify-center rounded-lg font-medium transition-all duration-300',
    // Magnetic effect class
    magnetic && 'will-change-transform',
    'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-space-void',
    'disabled:pointer-events-none disabled:opacity-50',
    // Variant styles - Galactic Tide theme
    {
      // Primary: Ocean blue with violet nebula glow
      'bg-sea-mid text-text-bright hover:bg-sea-deep focus-visible:ring-sea-surface shadow-[0_0_15px_var(--color-sea-mid)] hover:shadow-[0_0_25px_var(--color-nebula-violet)]': variant === 'primary',
      // Secondary: Sea blue subtle button
      'bg-sea-surface/20 text-sea-surface hover:bg-sea-surface/30 focus-visible:ring-sea-surface border border-sea-surface/30': variant === 'secondary',
      // Ghost: Transparent with hover effect
      'text-text-dim hover:bg-text-bright/10 hover:text-text-bright focus-visible:ring-text-bright': variant === 'ghost',
      // Outline: Stardust border with sea blue hover
      'border border-text-dim/50 bg-transparent text-text-dim hover:bg-sea-surface/10 hover:text-text-bright hover:border-sea-surface hover:shadow-[0_0_15px_rgba(0,191,255,0.1)] focus-visible:ring-text-bright': variant === 'outline',
    },
    // Size styles
    {
      'h-9 px-4 text-sm': size === 'sm',
      'h-11 px-6 text-base': size === 'md',
      'h-12 px-8 text-lg': size === 'lg',
    },
    className
  )}
  {...rest}
>
  <slot />
</Tag>

{/* Initialize magnetic effect for buttons with magnetic prop */}
{magnetic && (
  <script>
    import { applyMagneticEffect } from '../../lib/magnetic.js';

    // Apply to this specific button instance
    const buttons = document.querySelectorAll('[data-magnetic="true"]');
    buttons.forEach((btn) => {
      applyMagneticEffect(btn as HTMLElement, 20);
    });

    // Re-apply after View Transitions
    document.addEventListener('astro:after-swap', () => {
      const buttons = document.querySelectorAll('[data-magnetic="true"]');
      buttons.forEach((btn) => {
        applyMagneticEffect(btn as HTMLElement, 20);
      });
    });
  </script>
)}
