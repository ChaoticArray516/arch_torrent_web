---
import { cn } from '../../lib/utils';

/**
 * Tag Component
 * A simple badge/tag component for displaying categories, technologies, or labels.
 *
 * Features:
 * - Zero JavaScript - pure HTML/CSS rendered at build time
 * - Support for multiple color variants
 * - Compact sizing for inline display
 */

interface Props {
  /** Visual color variant */
  variant?: 'default' | 'primary' | 'secondary' | 'success' | 'warning' | 'info';
  /** Size preset */
  size?: 'sm' | 'md';
  /** Additional CSS classes */
  class?: string;
}

const {
  variant = 'default',
  size = 'sm',
  class: className,
  ...rest
} = Astro.props;
---

<span
  class={cn(
    // Base styles
    'inline-flex items-center rounded-full font-medium transition-colors duration-300',
    // Variant color styles - Galactic Tide theme
    {
      // Default: Starlight subtle
      'bg-text-bright/10 text-text-bright border border-text-bright/20': variant === 'default',
      // Primary: Sea surface blue with glow
      'bg-sea-surface/20 text-sea-surface border border-sea-surface/30 shadow-[0_0_10px_rgba(0,191,255,0.15)]': variant === 'primary',
      // Secondary: Nebula violet
      'bg-nebula-violet/20 text-nebula-violet border border-nebula-violet/30': variant === 'secondary',
      // Success: Bioluminescent aqua
      'bg-biolume-aqua/20 text-biolume-aqua border border-biolume-aqua/30': variant === 'success',
      // Warning: Stardust gold
      'bg-stardust-gold/20 text-stardust-gold border border-stardust-gold/30': variant === 'warning',
      // Info: Sea mid blue
      'bg-sea-mid/20 text-sea-mid border border-sea-mid/30': variant === 'info',
    },
    // Size styles
    {
      'px-2 py-0.5 text-xs': size === 'sm',
      'px-3 py-1 text-sm': size === 'md',
    },
    className
  )}
  {...rest}
>
  <slot />
</span>
