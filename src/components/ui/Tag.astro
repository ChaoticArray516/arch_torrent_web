---
import { cn } from '../../lib/utils';

/**
 * Tag Component
 * A simple badge/tag component for displaying categories, technologies, or labels.
 *
 * Features:
 * - Zero JavaScript - pure HTML/CSS rendered at build time
 * - Support for multiple color variants
 * - Compact sizing for inline display
 */

interface Props {
  /** Visual color variant */
  variant?: 'default' | 'primary' | 'secondary' | 'success' | 'warning' | 'info';
  /** Size preset */
  size?: 'sm' | 'md';
  /** Additional CSS classes */
  class?: string;
}

const {
  variant = 'default',
  size = 'sm',
  class: className,
  ...rest
} = Astro.props;
---

<span
  class={cn(
    // Base styles
    'inline-flex items-center rounded-full font-medium transition-colors duration-300',
    // Variant color styles - Cosmic Ocean theme
    {
      // Default: Starlight subtle
      'bg-star-light/10 text-star-light border border-star-light/20': variant === 'default',
      // Primary: Bioluminescent cyan
      'bg-biolume-cyan/20 text-biolume-cyan border border-biolume-cyan/30 shadow-[0_0_10px_rgba(51,187,197,0.15)]': variant === 'primary',
      // Secondary: Nebula purple
      'bg-nebula-purple/20 text-nebula-purple border border-nebula-purple/30': variant === 'secondary',
      // Success: Bioluminescent lime
      'bg-biolume-lime/20 text-biolume-lime border border-biolume-lime/30': variant === 'success',
      // Warning: Soft amber glow
      'bg-yellow-500/20 text-yellow-300 border border-yellow-500/30': variant === 'warning',
      // Info: Nebula blue
      'bg-nebula-blue/20 text-nebula-blue border border-nebula-blue/30': variant === 'info',
    },
    // Size styles
    {
      'px-2 py-0.5 text-xs': size === 'sm',
      'px-3 py-1 text-sm': size === 'md',
    },
    className
  )}
  {...rest}
>
  <slot />
</span>
