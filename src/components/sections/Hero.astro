---
import Button from '../ui/Button.astro';

/**
 * Hero Section Component
 * The main landing section of the portfolio website.
 *
 * Features:
 * - Zero JavaScript - pure HTML/CSS rendered at build time
 * - Responsive layout with centered content
 * - Call-to-action buttons
 * - Gradient background for visual appeal
 */

interface Props {
  /** Main headline text */
  title?: string;
  /** Subtitle/description text */
  subtitle?: string;
  /** Primary CTA text */
  primaryCtaText?: string;
  /** Primary CTA href */
  primaryCtaHref?: string;
  /** Secondary CTA text */
  secondaryCtaText?: string;
  /** Secondary CTA href */
  secondaryCtaHref?: string;
}

const {
  title = "Hi, I'm a Developer",
  subtitle = "I build fast, accessible, and beautiful web experiences with modern technologies.",
  primaryCtaText = 'View My Work',
  primaryCtaHref = '#projects',
  secondaryCtaText = 'Get in Touch',
  secondaryCtaHref = '#contact',
} = Astro.props;
---

<section
  class="relative min-h-[80vh] flex items-center justify-center overflow-hidden"
  aria-labelledby="hero-title"
>
  {/*
    Background removed - Starfield and Aurora components provide
    the Cosmic Ocean backdrop via Layout.astro
  */}

  <div class="container mx-auto px-4 py-16 text-center">
    {/* Badge - Galactic Tide glassmorphism style */}
    <div class="hero-animate mb-6" style="animation-delay: 0s;">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-space-ink/50 backdrop-blur-sm border border-sea-surface/30 text-sm font-medium text-text-bright shadow-[0_0_15px_rgba(0,191,255,0.2)]">
        <span class="w-2 h-2 rounded-full bg-stardust-gold animate-pulse shadow-[0_0_10px_rgba(255,215,0,0.8)]"></span>
        Available for new projects
      </span>
    </div>

    {/* Main heading with flowing gradient text effect */}
    <h1
      id="hero-title"
      class="hero-animate text-5xl sm:text-6xl md:text-7xl font-bold tracking-tight mb-6 bg-clip-text text-transparent bg-linear-to-r from-stardust-gold via-nebula-magenta to-sea-surface bg-size-[200%_auto] animate-[text-gradient-flow_5s_ease-in-out_infinite]"
      style="animation-delay: 0.2s;"
      transition:animate="slide"
    >
      {title}
    </h1>

    {/* Subtitle - delayed fade in */}
    <p class="hero-animate text-lg sm:text-xl text-text-dim max-w-2xl mx-auto mb-10 leading-relaxed" style="animation-delay: 0.5s;">
      {subtitle}
    </p>

    {/* CTA Buttons - delayed animation */}
    <div class="hero-animate flex flex-col sm:flex-row items-center justify-center gap-4" style="animation-delay: 0.8s;">
      <Button
        variant="primary"
        size="lg"
        href={primaryCtaHref}
        magnetic
      >
        {primaryCtaText}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 ml-2">
          <path fill-rule="evenodd" d="M10 3a.75.75 0 01.75.75v10.638l3.96-4.158a.75.75 0 111.08 1.04l-5.25 5.5a.75.75 0 01-1.08 0l-5.25-5.5a.75.75 0 111.08-1.04l3.96 4.158V3.75A.75.75 0 0110 3z" clip-rule="evenodd" />
        </svg>
      </Button>
      <Button
        variant="outline"
        size="lg"
        href={secondaryCtaHref}
      >
        {secondaryCtaText}
      </Button>
    </div>

    {/* Tech stack hint - Galactic Tide styled */}
    <div class="mt-16 pt-8 border-t border-text-bright/10">
      <p class="text-sm text-text-dim mb-4">Built with</p>
      <div class="flex flex-wrap items-center justify-center gap-6 text-text-dim">
        <span class="flex items-center gap-2 hover:text-sea-surface transition-colors duration-300">
          <svg class="w-6 h-6" viewBox="0 0 32 32" fill="currentColor">
            <path d="M16 2L2 6.5l2 17L16 30l12-6.5 2-17L16 2z"/>
          </svg>
          Astro
        </span>
        <span class="flex items-center gap-2 hover:text-sea-surface transition-colors duration-300">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
          </svg>
          React
        </span>
        <span class="flex items-center gap-2 hover:text-sea-surface transition-colors duration-300">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12.001,4.8c-3.2,0-5.2,1.6-6,4.8c1.2-1.6,2.6-2.2,4.2-1.8c0.913,0.228,1.565,0.89,2.288,1.624 C13.666,10.618,15.027,12,18.001,12c3.2,0,5.2-1.6,6-4.8c-1.2,1.6-2.6,2.2-4.2,1.8c-0.913-0.228-1.565-0.89-2.288-1.624 C16.337,6.182,14.976,4.8,12.001,4.8z M6.001,12c-3.2,0-5.2,1.6-6,4.8c1.2-1.6,2.6-2.2,4.2-1.8c0.913,0.228,1.565,0.89,2.288,1.624 c1.177,1.194,2.538,2.576,5.512,2.576c3.2,0,5.2-1.6,6-4.8c-1.2,1.6-2.6,2.2-4.2,1.8c-0.913-0.228-1.565-0.89-2.288-1.624 C10.337,13.382,8.976,12,6.001,12z"/>
          </svg>
          Tailwind CSS
        </span>
      </div>
    </div>
  </div>

  {/* Scroll indicator - Galactic Tide styling */}
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <a
      href="#projects"
      class="text-text-dim hover:text-sea-surface transition-colors duration-300"
      aria-label="Scroll to projects"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 drop-shadow-[0_0_8px_rgba(0,191,255,0.5)]">
        <path fill-rule="evenodd" d="M12 2.25a.75.75 0 01.75.75v16.19l6.22-6.22a.75.75 0 111.06 1.06l-7.5 7.5a.75.75 0 01-1.06 0l-7.5-7.5a.75.75 0 111.06-1.06l6.22 6.22V3a.75.75 0 01.75-.75z" clip-rule="evenodd" />
      </svg>
    </a>
  </div>
</section>

<style>
  /* Hero section animations - Tailwind v4 compatible */
  .hero-animate {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 1s ease-out forwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
