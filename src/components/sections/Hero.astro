---
import Button from '../ui/Button.astro';

/**
 * Hero Section Component
 * The main landing section of the portfolio website.
 *
 * Features:
 * - Zero JavaScript - pure HTML/CSS rendered at build time
 * - Responsive layout with centered content
 * - Call-to-action buttons
 * - Gradient background for visual appeal
 */

interface Props {
  /** Main headline text */
  title?: string;
  /** Subtitle/description text */
  subtitle?: string;
  /** Primary CTA text */
  primaryCtaText?: string;
  /** Primary CTA href */
  primaryCtaHref?: string;
  /** Secondary CTA text */
  secondaryCtaText?: string;
  /** Secondary CTA href */
  secondaryCtaHref?: string;
}

const {
  title = "Hi, I'm a Developer",
  subtitle = "I build fast, accessible, and beautiful web experiences with modern technologies.",
  primaryCtaText = 'View My Work',
  primaryCtaHref = '#projects',
  secondaryCtaText = 'Get in Touch',
  secondaryCtaHref = '#contact',
} = Astro.props;
---

<section
  class="relative min-h-[80vh] flex items-center justify-center overflow-hidden"
  aria-labelledby="hero-title"
>
  {/* Background gradient decoration */}
  <div
    class="absolute inset-0 -z-10"
    aria-hidden="true"
  >
    <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-white to-purple-50 dark:from-gray-900 dark:via-gray-900 dark:to-purple-950 transition-colors duration-200"></div>
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-blue-200 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-pulse"></div>
    <div class="absolute top-1/3 right-1/4 w-96 h-96 bg-purple-200 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-pulse" style="animation-delay: 2s;"></div>
    <div class="absolute bottom-1/4 left-1/3 w-96 h-96 bg-pink-200 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-pulse" style="animation-delay: 4s;"></div>
  </div>

  <div class="container mx-auto px-4 py-16 text-center">
    {/* Badge */}
    <div class="mb-6">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 backdrop-blur-sm border border-gray-200 text-sm font-medium text-gray-700 shadow-sm">
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
        Available for new projects
      </span>
    </div>

    {/* Main heading with view transition animation */}
    <h1
      id="hero-title"
      class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 dark:text-white tracking-tight mb-6"
      transition:animate="slide"
    >
      {title}
    </h1>

    {/* Subtitle */}
    <p class="text-lg sm:text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto mb-10 leading-relaxed">
      {subtitle}
    </p>

    {/* CTA Buttons */}
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <Button
        variant="primary"
        size="lg"
        href={primaryCtaHref}
      >
        {primaryCtaText}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 ml-2">
          <path fill-rule="evenodd" d="M10 3a.75.75 0 01.75.75v10.638l3.96-4.158a.75.75 0 111.08 1.04l-5.25 5.5a.75.75 0 01-1.08 0l-5.25-5.5a.75.75 0 111.08-1.04l3.96 4.158V3.75A.75.75 0 0110 3z" clip-rule="evenodd" />
        </svg>
      </Button>
      <Button
        variant="outline"
        size="lg"
        href={secondaryCtaHref}
      >
        {secondaryCtaText}
      </Button>
    </div>

    {/* Tech stack hint */}
    <div class="mt-16 pt-8 border-t border-gray-200/50">
      <p class="text-sm text-gray-500 mb-4">Built with</p>
      <div class="flex flex-wrap items-center justify-center gap-6 text-gray-400">
        <span class="flex items-center gap-2">
          <svg class="w-6 h-6" viewBox="0 0 32 32" fill="currentColor">
            <path d="M16 2L2 6.5l2 17L16 30l12-6.5 2-17L16 2z"/>
          </svg>
          Astro
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
          </svg>
          React
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12.001,4.8c-3.2,0-5.2,1.6-6,4.8c1.2-1.6,2.6-2.2,4.2-1.8c0.913,0.228,1.565,0.89,2.288,1.624 C13.666,10.618,15.027,12,18.001,12c3.2,0,5.2-1.6,6-4.8c-1.2,1.6-2.6,2.2-4.2,1.8c-0.913-0.228-1.565-0.89-2.288-1.624 C16.337,6.182,14.976,4.8,12.001,4.8z M6.001,12c-3.2,0-5.2,1.6-6,4.8c1.2-1.6,2.6-2.2,4.2-1.8c0.913,0.228,1.565,0.89,2.288,1.624 c1.177,1.194,2.538,2.576,5.512,2.576c3.2,0,5.2-1.6,6-4.8c-1.2,1.6-2.6,2.2-4.2,1.8c-0.913-0.228-1.565-0.89-2.288-1.624 C10.337,13.382,8.976,12,6.001,12z"/>
          </svg>
          Tailwind CSS
        </span>
      </div>
    </div>
  </div>

  {/* Scroll indicator */}
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <a
      href="#projects"
      class="text-gray-400 hover:text-gray-600 transition-colors"
      aria-label="Scroll to projects"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
        <path fill-rule="evenodd" d="M12 2.25a.75.75 0 01.75.75v16.19l6.22-6.22a.75.75 0 111.06 1.06l-7.5 7.5a.75.75 0 01-1.06 0l-7.5-7.5a.75.75 0 111.06-1.06l6.22 6.22V3a.75.75 0 01.75-.75z" clip-rule="evenodd" />
      </svg>
    </a>
  </div>
</section>
