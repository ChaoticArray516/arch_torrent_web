---
import { getCollection } from 'astro:content';
import ProjectCard from '../ui/ProjectCard.astro';
import ProjectFilter from '../interactive/ProjectFilter.tsx';

/**
 * ProjectGrid Section Component
 * Displays a grid of projects with category filtering.
 *
 * Features:
 * - Server-side data fetching from content collection at build time
 * - Filters out work-in-progress projects
 * - Sorts projects by publication date (newest first)
 * - Extracts unique categories for the filter component
 * - Combines static rendering with interactive filtering via Islands Architecture
 */

// Fetch all projects from content collection, filtering out WIP status
const allProjects = await getCollection('projects', ({ data }) => {
  return data.status !== 'wip';
});

// Sort projects by publication date in descending order (newest first)
allProjects.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

// Extract unique categories for the filter dropdown
// 'all' is prepended as the default option to show all projects
const categories = ['all', ...new Set(allProjects.map(p => p.data.category))];
---

<section id="projects" class="container mx-auto px-4 py-20">
  <h2 class="text-4xl font-bold tracking-tight text-center mb-4 text-star-light">
    Stellar Work
  </h2>
  <p class="text-lg text-star-dim text-center max-w-2xl mx-auto mb-12">
    A collection of galaxies I have explored and built.
  </p>

  <!-- Interactive Island: Project Filter
       The client:load directive tells Astro to hydrate this React component
       immediately when the page loads, enabling client-side interactivity -->
  <ProjectFilter client:load categories={categories} />

  <div id="project-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mt-8">
    {allProjects.map(project => (
      <div data-category={project.data.category} class="project-item">
        <ProjectCard project={project} />
      </div>
    ))}
  </div>

  <!-- Empty state shown when no projects match the filter -->
  <div id="no-projects" class="hidden text-center py-16">
    <p class="text-star-dim">No signals detected in this sector.</p>
  </div>
</section>

<script>
  /**
   * Client-side filtering script - Cosmic Ocean Theme
   *
   * Engineering Note:
   * This script subscribes to the Nano Store selectedCategory atom.
   * When the ProjectFilter component updates the store, this handler
   * animates the project cards in/out with smooth transitions.
   */
  import { selectedCategory } from '../../lib/store';

  const grid = document.getElementById('project-grid');
  const noProjects = document.getElementById('no-projects');

  if (grid) {
    const allItems = Array.from(grid.children) as HTMLElement[];

    selectedCategory.subscribe((category) => {
      let visibleCount = 0;

      allItems.forEach((item) => {
        const itemCategory = item.dataset.category;
        const shouldShow = category === 'all' || itemCategory === category;

        // Apply smooth transition
        item.style.transition = 'opacity 0.5s ease, transform 0.5s ease';

        if (shouldShow) {
          item.style.opacity = '1';
          item.style.transform = 'scale(1)';
          item.style.display = 'block';
          visibleCount++;
        } else {
          item.style.opacity = '0';
          item.style.transform = 'scale(0.9)';
          setTimeout(() => {
            if (selectedCategory.get() !== 'all' && item.dataset.category !== selectedCategory.get()) {
              item.style.display = 'none';
            }
          }, 500);
        }
      });

      // Toggle empty state
      if (noProjects) {
        noProjects.style.display = visibleCount === 0 ? 'block' : 'none';
      }
    });
  }
</script>
