---
/**
 * CodeBlock Component - Galactic Tide Theme v4.0
 * "Data Stream" console interface for code blocks.
 *
 * Starlight Commentary:
 * Code blocks simulate a spaceship console's "data stream" interface,
 * featuring glowing borders and a top "title bar" with colored status dots.
 * This transforms static code into a sci-fi data terminal aesthetic.
 */
---

<div class="my-8 rounded-lg border border-sea-mid/20 bg-space-ink/70 backdrop-blur-sm overflow-hidden shadow-2xl shadow-sea-deep/10">
  <!-- Console title bar with status indicators -->
  <div class="px-4 py-2 border-b border-sea-mid/20 text-xs text-text-dim flex items-center gap-2">
    <span class="w-3 h-3 rounded-full bg-stardust-red"></span>
    <span class="w-3 h-3 rounded-full bg-stardust-gold"></span>
    <span class="w-3 h-3 rounded-full bg-biolume-aqua"></span>
    <span class="ml-auto font-mono tracking-wider">DATA_STREAM</span>
  </div>

  <!-- Code content area -->
  <div class="p-4 overflow-x-auto">
    <slot />
  </div>
</div>
