---
/**
 * Starfield Canvas Component - Galactic Tide Theme v4.0
 *
 * Starlight Commentary:
 * A single-color starfield cannot constitute a "colorful" cosmos. The true galaxy
 * is filled with stars of different color temperatures. We introduce a color array
 * containing multiple stellar hues. When initializing each star, we randomly assign
 * it a color from this palette instead of fixed white. Additionally, we introduce
 * a "twinkle" animation, giving some stars independent, random flickering cycles,
 * creating a more vivid, realistic starfield.
 *
 * Engineering Note:
 * The Canvas API remains our "warp drive" for rendering thousands of stars efficiently.
 * Instead of using hundreds of DOM elements that would cause performance "gravitational collapse",
 * we draw all stars on a single canvas, manipulating pixels directly for maximum efficiency.
 * This ensures smooth animation even on lower-end devices.
 */
---

<canvas id="starfield-canvas" class="fixed top-0 left-0 w-full h-full -z-20 pointer-events-none"></canvas>

<script>
  // Initialize starfield animation on page load
  function initStarfield() {
    const canvas = document.getElementById("starfield-canvas") as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    // v4.0: Colorful starfield color palette
    const STAR_COLORS = [
      "#ffffff",  // White
      "#ffd700",  // Gold
      "#ff69b4",  // HotPink
      "#00bfff",  // DeepSkyBlue
      "#00ffff",  // Cyan
    ];

    interface Star {
      x: number;
      y: number;
      size: number;
      color: string;
      baseAlpha: number;
      twinkleSpeed: number;
      twinkleOffset: number;
    }

    let stars: Star[] = [];
    const numStars = 800; // Star count for good density

    function resizeCanvas() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }

    // Initialize stars with random positions and properties
    function initStars() {
      stars = [];
      for (let i = 0; i < numStars; i++) {
        stars.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          size: Math.random() * 1.5 + 0.5,
          // v4.0: Randomly assign color from palette
          color: STAR_COLORS[Math.floor(Math.random() * STAR_COLORS.length)],
          baseAlpha: Math.random() * 0.5 + 0.4, // Brighter stars
          twinkleSpeed: Math.random() * 2 + 0.5,
          twinkleOffset: Math.random() * Math.PI * 2,
        });
      }
    }

    let frame = 0;

    // Draw stars on canvas
    function drawStars() {
      if (!ctx) return;

      // Clear and draw solid background
      ctx.fillStyle = "#020617";
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      const time = frame * 0.016; // approximate seconds

      stars.forEach((star, i) => {
        // Calculate twinkle
        const twinkle = Math.sin(time * star.twinkleSpeed + star.twinkleOffset) * 0.5 + 0.5;
        const alpha = star.baseAlpha * (0.6 + twinkle * 0.4);

        ctx.fillStyle = star.color;
        ctx.globalAlpha = alpha;
        ctx.beginPath();
        ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);
        ctx.fill();
      });

      ctx.globalAlpha = 1;
    }

    // Animation loop
    function animate() {
      drawStars();
      frame++;
      requestAnimationFrame(animate);
    }

    // Initialize and start
    window.addEventListener("resize", () => {
      resizeCanvas();
      initStars();
    });

    resizeCanvas();
    initStars();
    animate();
  }

  // Initialize immediately - this script is a module and runs after DOM is ready
  initStarfield();
</script>
