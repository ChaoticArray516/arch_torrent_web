---
/**
 * Starfield Canvas Component - Cosmic Ocean Theme v3.1
 *
 * Engineering Note:
 * The Canvas API is our "warp drive" for rendering thousands of stars efficiently.
 * Instead of using hundreds of DOM elements that would cause performance "gravitational collapse",
 * we draw all stars on a single canvas, manipulating pixels directly for maximum efficiency.
 * This ensures smooth animation even on lower-end devices.
 */
---

<canvas id="starfield-canvas" class="fixed top-0 left-0 w-full h-full -z-10"></canvas>

<script>
  // Wait for document to load, ensuring canvas element is ready
  document.addEventListener("DOMContentLoaded", () => {
    const canvas = document.getElementById("starfield-canvas") as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    interface Star {
      x: number;
      y: number;
      z: number;
      size: number;
      opacity: number;
    }

    let stars: Star[] = [];
    const numStars = 800; // Number of stars, adjustable based on performance
    const speed = 0.05;   // Star movement speed

    function resizeCanvas() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }

    // Initialize stars with random positions
    function initStars() {
      stars = [];
      for (let i = 0; i < numStars; i++) {
        stars.push({
          x: Math.random() * canvas.width - canvas.width / 2,
          y: Math.random() * canvas.height - canvas.height / 2,
          z: Math.random() * canvas.width, // Z-axis depth for parallax simulation
          size: Math.random() * 2 + 0.5, // Star size
          opacity: Math.random() * 0.5 + 0.2, // Star opacity
        });
      }
    }

    // Draw stars on canvas
    function drawStars() {
      if (!ctx) return;

      // Clear canvas with ocean-deep background for trail effect
      ctx.fillStyle = "rgba(13, 17, 23, 0.3)";
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      stars.forEach(star => {
        // Project 3D coordinates to 2D plane
        const k = 128 / star.z;
        const px = star.x * k + canvas.width / 2;
        const py = star.y * k + canvas.height / 2;

        if (px >= 0 && px <= canvas.width && py >= 0 && py <= canvas.height) {
          const size = star.size * k;
          // Use star-light color with star's own opacity
          const alpha = Math.min(star.opacity * k * 0.5, 1);
          ctx.fillStyle = `rgba(230, 237, 243, ${alpha})`;
          ctx.beginPath();
          ctx.arc(px, py, Math.max(size / 2, 0.5), 0, Math.PI * 2);
          ctx.fill();

          // Add glow effect for brighter stars
          if (alpha > 0.6) {
            ctx.fillStyle = `rgba(51, 187, 197, ${alpha * 0.3})`;
            ctx.beginPath();
            ctx.arc(px, py, Math.max(size, 1), 0, Math.PI * 2);
            ctx.fill();
          }
        }
      });
    }

    // Update star positions to create flow effect
    function updateStars() {
      stars.forEach(star => {
        star.z -= speed;
        if (star.z <= 0) {
          // Reset star position when it moves out of view
          star.z = canvas.width;
          star.x = Math.random() * canvas.width - canvas.width / 2;
          star.y = Math.random() * canvas.height - canvas.height / 2;
        }
      });
    }

    // Animation loop
    function animate() {
      updateStars();
      drawStars();
      requestAnimationFrame(animate);
    }

    // Initialize and start
    window.addEventListener("resize", () => {
      resizeCanvas();
      initStars();
    });

    resizeCanvas();
    initStars();
    animate();
  });
</script>
